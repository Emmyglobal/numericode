# Vercel Postgres / Neon connection.
# Vercel injects these automatically when you connect a database integration.
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Required for the one-time protected setup endpoint.
SETUP_SECRET=replace-with-a-long-random-secret
FIRST_ADMIN_NAME=NumeriCode Admin
FIRST_ADMIN_EMAIL=admin@yourdomain.com
FIRST_ADMIN_PASSWORD=replace-with-a-long-unique-password
FIRST_TRAINER_NAME=Lead Trainer
FIRST_TRAINER_EMAIL=trainer@yourdomain.com
FIRST_TRAINER_PASSWORD=replace-with-a-long-unique-password

# Optional, but recommended for launch password reset emails.
APP_URL=https://your-vercel-project.vercel.app
RESEND_API_KEY=
AUTH_EMAIL_FROM=NumeriCode <auth@yourdomain.com>

# Google Ads.
VITE_GOOGLE_ADS_ID=AW-XXXXXXXXXX
VITE_GOOGLE_ADS_SIGNUP_LABEL=XXXXXXXXXXXX
